{
  "name": "aios-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "Local-only read-only AIOS Control Center MVP.",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm inventory:generate && pnpm --filter @aios-control/frontend dev",
    "build": "pnpm inventory:generate && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "inventory:generate": "pnpm --filter @aios-control/server inventory:generate",
    "validate": "pnpm typecheck && pnpm build"
  },
  "engines": {
    "node": ">=22"
  }
}
